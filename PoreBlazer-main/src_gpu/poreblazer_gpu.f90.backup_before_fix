!--------------------------------------------------------------------------------------
! GPU-accelerated subroutines for PoreBlazer v4.0
!
! Uses OpenACC directives with NVIDIA HPC SDK (nvfortran)
! Accelerates the two main computational hot spots:
!   1. lattice_calculations  — 3D grid × atoms distance calculations
!   2. surface_area          — Monte Carlo surface sampling
!
! Compile with: nvfortran -acc -gpu=cc89 -O3 -Minfo=accel ...
!--------------------------------------------------------------------------------------

!--------------------------------------------------------------------------------------
! Verlet neighbor list module for GPU surface area acceleration
!
! Stores, for each atom i, the list of atom indices k that are close enough that
! a test point on atom i's surface could potentially overlap with atom k.
! This reduces the inner overlap test from O(natoms) to O(avg_neighbors).
!--------------------------------------------------------------------------------------
module verlet_mod
    integer, allocatable :: vlist(:,:)      ! neighbor indices: vlist(i, 1:nneighbors(i))
    integer, allocatable :: nneighbors(:)   ! neighbor count per atom
    integer :: max_neighbors                ! max neighbors across all atoms
end module verlet_mod

!--------------------------------------------------------------------------------------

!--------------------------------------------------------------------------------------
! GPU-accelerated lattice_calculations
!
! This is the dominant hot spot (~95% of runtime). The algorithm:
!   For each cubelet in the 3D grid (ncubesx × ncubesy × ncubesz):
!     For each atom in the structure:
!       - compute minimum-image distance
!       - check if cubelet center is inside an atom (overlap)
!       - track nearest atom distance
!       - compute LJ interaction with helium probe
!
! GPU strategy: Parallelize the 3D cubelet loop. Each GPU thread handles one
! cubelet and loops over all atoms sequentially (coalesced reads from atom data).
! A compaction pass on CPU fills the variable-length output arrays (g_cubes,
! he_cubes, n_cubes) to avoid atomic operations in the GPU kernel.
!
! For orthorhombic cells (the common case for MOFs/zeolites), the minimum-image
! calculation is inlined directly. Non-orthorhombic cells fall back to CPU.
!--------------------------------------------------------------------------------------
subroutine lattice_calculations_gpu
    use parameters
    use atoms
    use adsorbent
    use lattice
    use defaults, only: rdbl
    implicit none

    ! Cell geometry — extracted from fcell as plain types for GPU
    real*8  :: ell(3)
    logical :: ortho

    ! Loop variables
    integer :: i, j, k, l, icount, tile_start, tile_end

    ! Per-cubelet temporaries
    real*8  :: xc, yc, zc
    real*8  :: d1, d2, d3, rdist2, rdist2_ref
    real*8  :: rdist_surface, rdist_surface_ref, lj_local
    real*8  :: sig2_rdist2, rdist6, rdist12, lj_energy
    logical :: overlap
    integer :: imin

    ! Compaction counters
    integer :: ng, nhe, nn

    ! Timer
    integer*8 :: t1, t2, t_rate, t_max
    real*8 :: elapsed


    ! Per-cubelet persistent state for tiled atom processing
    ! (keeps atom data in L1 cache — each 256-atom tile is only 6 KB)
    integer*2, allocatable :: ovlap(:,:,:)     ! 0 = processing, 1 = overlap found
    real*8, allocatable    :: r2ref(:,:,:)      ! running min center distance^2
    real*8, allocatable    :: rsurf(:,:,:)      ! running min surface distance
    integer*2, allocatable :: imin_arr(:,:,:)   ! nearest atom index

    integer, parameter :: TILE_SZ = 256
    call system_clock(t1, t_rate, t_max)

    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU-accelerated lattice calculations (OpenACC)         !"
    write(*,*) "!-------------------------------------------------------!"
    write(*,*)

    ! Check if cell is orthorhombic — non-ortho falls back to CPU
    ortho = fcell%orthoflag
    if(.not. ortho) then
        write(*,*) "  Non-orthorhombic cell detected — using CPU version"
        call lattice_calculations
        return
    end if

    ! Extract cell dimensions
    ell = fcell%ell

    ! Initialize output arrays
    lattice_space = 0; lattice_space_he = 0; lattice_space_n = 0
    lattice_rdist2 = 0.0d0; lattice_lj_he = 0.0d0
    g_cubes = 0; he_cubes = 0; n_cubes = 0

    ! Allocate tiling state arrays
    allocate(ovlap(ncubesx, ncubesy, ncubesz))
    allocate(r2ref(ncubesx, ncubesy, ncubesz))
    allocate(rsurf(ncubesx, ncubesy, ncubesz))
    allocate(imin_arr(ncubesx, ncubesy, ncubesz))

    !####################################################################
    ! GPU KERNELS: Tiled atom processing
    !
    ! Instead of one large kernel where every gang loops over ALL atoms
    ! (2208) per cubelet, we process atoms in tiles of 256. This keeps
    ! coords_temp in GPU L1 cache — 256 atoms × 3 coords × 8 bytes
    ! = 6 KB per tile, well within the 80 KB L1 per SM.
    !
    ! Per-cubelet state accumulated across tiles:
    !   ovlap(j,k,l) — 1 if an overlapping atom was found
    !   r2ref(j,k,l) — running minimum center distance^2
    !   rsurf(j,k,l) — running minimum surface distance
    !   imin_arr(j,k,l) — atom index of nearest atom
    !   lattice_lj_he(icount) — running LJ sum
    !
    ! No compaction arrays on GPU — use lattice_space as marker.
    ! lattice_index computed on CPU after (saves 3 × ntot × 4 bytes VRAM).
    !####################################################################
    write(*,*) "  [DEBUG] nc_local=", nc_local, " ncycles=", ncycles, " nbins=", nbins
    write(*,*) "  [DEBUG] ng_cubes=", ng_cubes, " nn_cubes=", nn_cubes, " ntot=", ntot
    write(*,*) "  [DEBUG] ncubesx=", ncubesx, " ncubesy=", ncubesy, " ncubesz=", ncubesz
    write(*,*) "  [DEBUG] is_total=", is_total, " size(PA1)=", size(PA1)
    !$acc enter data copyin(coords_temp, asigma2, asigma2_he, aeps_he, &
    !$acc&   asigma, asigma2_n, atype, ell, hicut2, cube_size, &
    !$acc&   ncubesx, ncubesy, ncubesz, natoms) &
    !$acc&   create(lattice_space, lattice_rdist2, lattice_space_he, &
    !$acc&   lattice_space_n, lattice_lj_he) &
    !$acc&   create(ovlap, r2ref, rsurf, imin_arr)

    !--- Initialize tiling state arrays ---
    !$acc parallel loop collapse(3) gang vector_length(128) &
    !$acc& present(ovlap, r2ref, rsurf, imin_arr)
    do l=1, ncubesz
        do k=1, ncubesy
            do j=1, ncubesx
                ovlap(j,k,l) = 0
                r2ref(j,k,l) = huge(0.0d0)
                rsurf(j,k,l) = huge(0.0d0)
                imin_arr(j,k,l) = 1
            end do
        end do
    end do

    !--- Initialize LJ accumulator ---
    !$acc parallel loop gang vector_length(128) &
    !$acc& present(lattice_lj_he)
    do icount=1, ntot
        lattice_lj_he(icount) = 0.0d0
    end do

    !--- Process atoms in tiles for L1 cache efficiency ---
    TILE_LOOP: do tile_start = 1, natoms, TILE_SZ
        tile_end = min(tile_start + TILE_SZ - 1, natoms)

        !$acc parallel loop collapse(3) gang vector_length(128) &
        !$acc& private(xc, yc, zc, d1, d2, d3, rdist2, rdist2_ref, overlap, &
        !$acc&   rdist_surface, rdist_surface_ref, imin, lj_local, &
        !$acc&   sig2_rdist2, rdist6, rdist12, lj_energy, icount) &
        !$acc& firstprivate(ell, cube_size, hicut2, tile_start, tile_end) &
        !$acc& present(coords_temp, asigma2, asigma2_he, aeps_he, asigma, &
        !$acc&   asigma2_n, atype, ovlap, r2ref, rsurf, imin_arr, &
        !$acc&   lattice_rdist2, lattice_lj_he, &
        !$acc&   ncubesx, ncubesy, ncubesz)
        do l=1, ncubesz
            do k=1, ncubesy
                do j=1, ncubesx

                    !--- Skip cubelets that already found overlap ---
                    if(ovlap(j,k,l) == 1) cycle

                    !--- Cubelet center coordinates (slanted frame) ---
                    xc = dble(j-1)*cube_size + 0.5d0*cube_size
                    yc = dble(k-1)*cube_size + 0.5d0*cube_size
                    zc = dble(l-1)*cube_size + 0.5d0*cube_size

                    !--- Load persistent state accumulated from prior tiles ---
                    overlap = .false.
                    rdist2_ref = r2ref(j,k,l)
                    rdist_surface_ref = rsurf(j,k,l)
                    imin = imin_arr(j,k,l)
                    icount = (l-1)*ncubesx*ncubesy + (k-1)*ncubesx + j
                    lj_local = lattice_lj_he(icount)

                    !--- Loop over atoms in current tile ---
                    do i=tile_start, tile_end
                        ! Minimum-image distance (orthorhombic fast path)
                        d1 = xc - coords_temp(1, i)
                        d2 = yc - coords_temp(2, i)
                        d3 = zc - coords_temp(3, i)
                        d1 = d1 - ell(1)*anint(d1/ell(1))
                        d2 = d2 - ell(2)*anint(d2/ell(2))
                        d3 = d3 - ell(3)*anint(d3/ell(3))
                        rdist2 = d1*d1 + d2*d2 + d3*d3

                        !--- Overlap check: cube center inside an atom? ---
                        if(rdist2 < 0.25d0*asigma2(atype(i))) then
                            overlap = .true.
                            ovlap(j,k,l) = 1
                            exit
                        end if

                        !--- Track nearest atom ---
                        if(rdist2 < rdist2_ref) then
                            rdist2_ref = rdist2
                            imin = i
                        end if

                        !--- Track shortest surface distance ---
                        rdist_surface = dsqrt(rdist2) - 0.5d0*asigma(atype(i))
                        if(rdist_surface < rdist_surface_ref) then
                            rdist_surface_ref = rdist_surface
                        end if

                        !--- LJ interaction with helium probe (within cutoff) ---
                        if(rdist2 < hicut2) then
                            sig2_rdist2 = asigma2_he(atype(i))/rdist2
                            rdist6 = sig2_rdist2*sig2_rdist2*sig2_rdist2
                            rdist12 = rdist6*rdist6
                            lj_energy = aeps_he(atype(i))*(rdist12 - rdist6)
                            lj_local = lj_local + lj_energy
                        end if
                    end do  ! i = tile_start, tile_end

                    !--- Persist state for next tile ---
                    r2ref(j,k,l) = rdist2_ref
                    rsurf(j,k,l) = rdist_surface_ref
                    imin_arr(j,k,l) = imin
                    lattice_lj_he(icount) = lj_local

                end do  ! j
            end do  ! k
        end do  ! l
        !$acc end parallel loop
    end do TILE_LOOP

    !####################################################################
    ! Final output: compute lattice flags from accumulated tile state
    ! Done in a separate kernel to avoid tile-loop overhead.
    !####################################################################
    !$acc parallel loop collapse(3) gang vector_length(128) &
    !$acc& present(lattice_space, lattice_rdist2, lattice_space_he, &
    !$acc&   lattice_space_n, ovlap, rsurf, r2ref, imin_arr, &
    !$acc&   asigma2_he, asigma2_n, atype, ncubesx, ncubesy, ncubesz)
    do l=1, ncubesz
        do k=1, ncubesy
            do j=1, ncubesx
                if(ovlap(j,k,l) == 1) cycle

                !--- Register as geometrically accessible (point probe) ---
                lattice_space(j, k, l) = 1
                lattice_rdist2(j, k, l) = rsurf(j,k,l) * rsurf(j,k,l)

                !--- Helium accessibility ---
                if(r2ref(j,k,l) > 0.25d0*asigma2_he(atype(imin_arr(j,k,l)))) then
                    lattice_space_he(j, k, l) = 1
                end if

                !--- Nitrogen accessibility ---
                if(r2ref(j,k,l) > asigma2_n(atype(imin_arr(j,k,l)))) then
                    lattice_space_n(j, k, l) = 1
                end if
            end do
        end do
    end do
    !$acc end parallel loop

    !####################################################################
    ! Data transfer: copy results back from GPU
    !####################################################################
    !$acc exit data copyout(lattice_space, lattice_rdist2, lattice_space_he, &
    !$acc&   lattice_space_n, lattice_lj_he) &
    !$acc& delete(ovlap, r2ref, rsurf, imin_arr)

    !####################################################################
    ! CPU compaction: use lattice_space markers + recompute icount
    ! This avoids storing 3 large g_valid/he_valid/n_valid arrays on GPU.
    !####################################################################
    ng = 0; nhe = 0; nn = 0
    do l=1, ncubesz
        do k=1, ncubesy
            do j=1, ncubesx
                icount = (l-1)*ncubesx*ncubesy + (k-1)*ncubesx + j
                if(lattice_space(j,k,l) == 1) then
                    ng = ng + 1
                    g_cubes(ng) = icount
                end if
                if(lattice_space_he(j,k,l) == 1) then
                    nhe = nhe + 1
                    he_cubes(nhe) = icount
                end if
                if(lattice_space_n(j,k,l) == 1) then
                    nn = nn + 1
                    n_cubes(nn) = icount
                end if
            end do
        end do
    end do

    ng_cubes = ng
    nhe_cubes = nhe
    nn_cubes = nn

    !--- Compute lattice_index on CPU (was done on GPU before, moved to save VRAM) ---
    do icount = 1, ntot
        l = (icount - 1) / (ncubesx * ncubesy) + 1
        k = modulo((icount - 1) / ncubesx, ncubesy) + 1
        j = modulo(icount - 1, ncubesx) + 1
        lattice_index(1, icount) = j
        lattice_index(2, icount) = k
        lattice_index(3, icount) = l
    end do

    !--- Allocate percolation arrays ---
    allocate(PA1(ng_cubes), PA2(ng_cubes), PA3(ng_cubes), PA4(ng_cubes))
    PA1 = 0.0d0; PA2 = 0; PA3 = 0; PA4 = 0

    write(*,'(a,i10)') "  Cubelets accessible to point probe:  ", ng_cubes
    write(*,'(a,i10)') "  Cubelets accessible to helium:       ", nhe_cubes
    write(*,'(a,i10)') "  Cubelets accessible to nitrogen:     ", nn_cubes
    write(*,*)
    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU lattice calculations complete                      !"
    write(*,*) "!-------------------------------------------------------!"
    write(*,*)

    call system_clock(t2)
    elapsed = dble(t2 - t1) / dble(t_rate)
    write(*,'(a,f8.2,a)') "  [TIMING] Lattice kernel took ", elapsed, " seconds"

    return
end subroutine lattice_calculations_gpu


!--------------------------------------------------------------------------------------
! Build Verlet neighbor list for GPU surface area overlap optimization
!
! For each atom i, find all atoms k such that a test point on i's surface
! could potentially overlap with k. This reduces the inner overlap loop in
! surface_area_gpu from O(natoms) to O(avg_neighbors).
!
! Overlap condition for a test point on atom i:
!   dist(atom_i_center, atom_k_center) < coeff_surface * (sigma_n(i) + sigma_n(k))
!
! The test point is at distance coeff_surface * sigma_n(i) from atom i's center.
! For overlap, the test point must be within coeff_surface * sigma_n(k) of atom k.
! By triangle inequality:
!   dist(i_center, k_center) < coeff_surface * (sigma_n(i) + sigma_n(k))
!
! Use a conservative bound with max sigma_n so one neighbor list works for all atoms.
! Only valid for orthorhombic cells (same constraint as surface_area_gpu).
!--------------------------------------------------------------------------------------
subroutine build_verlet_list
    use parameters
    use atoms
    use adsorbent
    use verlet_mod
    implicit none
    real*8 :: max_sigma_n, rmax, rmax2, d1, d2, d3, rdist2
    integer :: i, k

    write(*,*) "  Building Verlet neighbor list..."

    ! Find maximum asigma_n across all types
    max_sigma_n = maxval(asigma_n)

    ! Maximum overlap search radius (conservative — uses max sigma_n for both atoms)
    rmax = coeff_surface * 2.0d0 * max_sigma_n
    rmax2 = rmax * rmax

    ! Allocate / initialize neighbor count array
    if(.not. allocated(nneighbors)) allocate(nneighbors(natoms))
    nneighbors = 0

    ! First pass: count neighbors per atom
    do i = 1, natoms
        do k = 1, natoms
            if(k == i) cycle
            d1 = coords(1,i) - coords(1,k)
            d2 = coords(2,i) - coords(2,k)
            d3 = coords(3,i) - coords(3,k)
            d1 = d1 - fcell%ell(1)*anint(d1/fcell%ell(1))
            d2 = d2 - fcell%ell(2)*anint(d2/fcell%ell(2))
            d3 = d3 - fcell%ell(3)*anint(d3/fcell%ell(3))
            rdist2 = d1*d1 + d2*d2 + d3*d3
            if(rdist2 < rmax2) then
                nneighbors(i) = nneighbors(i) + 1
            end if
        end do
    end do

    ! Find max neighbors (for 2D array allocation)
    max_neighbors = maxval(nneighbors)

    ! Allocate 2D neighbor list array
    if(allocated(vlist)) deallocate(vlist)
    allocate(vlist(natoms, max_neighbors))
    vlist = 0

    ! Second pass: fill neighbor lists
    nneighbors = 0
    do i = 1, natoms
        do k = 1, natoms
            if(k == i) cycle
            d1 = coords(1,i) - coords(1,k)
            d2 = coords(2,i) - coords(2,k)
            d3 = coords(3,i) - coords(3,k)
            d1 = d1 - fcell%ell(1)*anint(d1/fcell%ell(1))
            d2 = d2 - fcell%ell(2)*anint(d2/fcell%ell(2))
            d3 = d3 - fcell%ell(3)*anint(d3/fcell%ell(3))
            rdist2 = d1*d1 + d2*d2 + d3*d3
            if(rdist2 < rmax2) then
                nneighbors(i) = nneighbors(i) + 1
                vlist(i, nneighbors(i)) = k
            end if
        end do
    end do

    write(*,'(a,i6,a,i4)') "  Verlet: max neighbors = ", max_neighbors, &
        "  (avg = ", nint(sum(dble(nneighbors))/natoms), ")"

end subroutine build_verlet_list


!--------------------------------------------------------------------------------------
! GPU-accelerated surface_area
!
! For each atom, nsample random surface points are generated and tested against
! all other atoms for overlap. The fraction of successful trials gives the
! accessible surface area.
!
! GPU strategy: Parallelize over atoms. Each GPU thread:
!   1. Generates random directions using a thread-local LCG
!   2. Creates test points and applies PBC
!   3. Checks overlap against all other atoms (inner reduction)
!   4. Accumulates successful trials
!
! Uses a thread-safe inline LCG random number generator (no external library).
! The cell is assumed orthorhombic (most common case); falls back to CPU otherwise.
!--------------------------------------------------------------------------------------
subroutine surface_area_gpu
    use parameters
    use atoms
    use adsorbent
    use lattice
    use defaults, only: rdbl, pi
    use results
    use verlet_mod
    implicit none

    ! Local variables
    real*8  :: ell(3), hcut2_loc
    integer :: i, j, k, n, nx, ny, nz
    real*8  :: phi, costheta, theta
    real*8  :: rdist2, sfrac, sjreal, stotalreduced, vol
    real*8  :: d1, d2, d3
    real*8  :: xp, yp, zp, rn
    logical :: deny
    logical :: ortho

    ! Thread-local RNG state (64-bit for overflow-safe LCG)
    integer*8 :: seed, new_seed

    ! Per-atom counters (output from GPU kernel)
    integer, allocatable :: ncount_arr(:)

    ! Timer
    integer*8 :: t1, t2, t_rate, t_max
    real*8 :: elapsed
    call system_clock(t1, t_rate, t_max)


    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU-accelerated surface area (OpenACC)                 !"
    write(*,*) "!-------------------------------------------------------!"
    write(*,*)

    ! Fall back to CPU for non-orthorhombic cells
    ortho = fcell%orthoflag
    if(.not. ortho) then
        write(*,*) "  Non-orthorhombic cell detected — using CPU version"
        call surface_area
        return
    end if

    ! Quick return if no nitrogen-accessible points
    if(nn_cubes == 0) then
        stotal = 0.0d0
        vol = fundcell_getvolume(fcell)
        stotalreduced = stotal/(vol)*1.0d4
        write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
            ' surface area in A^2:                 ', stotal
        write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
            ' surface area per volume in m^2/cm^3: ', stotalreduced
        write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
            ' surface area per mass in m^2/g:      ', &
            stotalreduced / (smass/(0.6022141d0*vol))
        write(*,*) "  No nitrogen accessible surface area"
        write(*,*)
        write(*,*) "!-------------------------------------------------------!"
        write(*,*) "! GPU surface area calculations complete                 !"
        write(*,*)
        write(100,*) property
        write(100,'(a,f12.2)') "S_AC_A^2 ", stotal
        write(100,'(a,f12.2)') "S_AC_m^2/cm^3 ", stotalreduced
        write(100,'(a,f12.2)') "S_AC_m^2/g ", &
            stotalreduced / (smass/(0.6022141d0*vol))
        return
    end if

    ! Extract cell info
    ell = fcell%ell
    hcut2_loc = hicut2

    ! Per-atom trial counter
    allocate(ncount_arr(natoms))
    ncount_arr = 0

    ! Build Verlet neighbor list for GPU overlap test
    call build_verlet_list

    !####################################################################
    ! GPU KERNEL: Parallel over atoms
    ! Inline LCG to avoid OpenACC reference argument issues with
    ! intent(inout) function parameters.
    ! LCG: x_{n+1} = (1664525 * x_n + 1013904223) mod 2^31
    ! Uses 64-bit integers for overflow-safe arithmetic.
    !####################################################################
    !$acc enter data create(ncount_arr)
    write(*,*) "  [DEBUG] nc_local=", nc_local, " ncycles=", ncycles, " nbins=", nbins
    write(*,*) "  [DEBUG] ng_cubes=", ng_cubes, " nn_cubes=", nn_cubes, " ntot=", ntot
    write(*,*) "  [DEBUG] ncubesx=", ncubesx, " ncubesy=", ncubesy, " ncubesz=", ncubesz
    write(*,*) "  [DEBUG] is_total=", is_total, " size(PA1)=", size(PA1)
    !$acc enter data copyin(coords, asigma_n, asigma2_n, atype, &
    !$acc&   lattice_space_n, vlist, nneighbors, max_neighbors)

    !$acc parallel loop gang vector_length(128) &
    !$acc& private(j, k, n, phi, costheta, theta, xp, yp, zp, d1, d2, d3, &
    !$acc&   rdist2, deny, nx, ny, nz, seed, new_seed, rn) &
    !$acc& firstprivate(ell, coeff_surface, coeff_surface2, cube_size, &
    !$acc&   natoms, nsample, ncubesx, ncubesy, ncubesz) &
    !$acc& present(coords, asigma_n, asigma2_n, atype, ncount_arr, &
    !$acc&   lattice_space_n, vlist, nneighbors)
    do i=1, natoms
        ! Initialize thread-local RNG seed (64-bit, no overflow)
        seed = 1_8 + i * 694847539_8
        ncount_arr(i) = 0

        do j=1, nsample
            !--- Generate random number #1 (phi) — inline LCG ---
            new_seed = mod(1664525_8 * seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            phi = pi - rn * 2.0d0 * pi

            !--- Generate random number #2 (costheta) — inline LCG ---
            new_seed = mod(1664525_8 * seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            costheta = 1.0d0 - rn * 2.0d0
            ! Clamp to [-1, 1] for acos stability
            if(costheta > 1.0d0) costheta = 1.0d0
            if(costheta < -1.0d0) costheta = -1.0d0
            theta = acos(costheta)

            !--- Test point on atom i surface ---
            xp = sin(theta) * cos(phi) * (coeff_surface * asigma_n(atype(i))) &
                 + coords(1, i)
            yp = sin(theta) * sin(phi) * (coeff_surface * asigma_n(atype(i))) &
                 + coords(2, i)
            zp = costheta * (coeff_surface * asigma_n(atype(i))) &
                 + coords(3, i)

            !--- Apply PBC (orthorhombic) ---
            d1 = xp - ell(1)*anint(xp/ell(1))
            d2 = yp - ell(2)*anint(yp/ell(2))
            d3 = zp - ell(3)*anint(zp/ell(3))
            if(d1 < 0.0d0) d1 = d1 + ell(1)
            if(d1 >= ell(1)) d1 = d1 - ell(1)
            if(d2 < 0.0d0) d2 = d2 + ell(2)
            if(d2 >= ell(2)) d2 = d2 - ell(2)
            if(d3 < 0.0d0) d3 = d3 + ell(3)
            if(d3 >= ell(3)) d3 = d3 - ell(3)
            xp = d1; yp = d2; zp = d3

            !--- Locate cubelet containing test point ---
            nx = int(xp / cube_size) + 1
            ny = int(yp / cube_size) + 1
            nz = int(zp / cube_size) + 1

            ! Periodic boundary for cubelet index
            if(nx > ncubesx) nx = nx - (nx/ncubesx)*ncubesx
            if(nx < 1) nx = nx + (1-(nx/ncubesx))*ncubesx
            if(ny > ncubesy) ny = ny - (ny/ncubesy)*ncubesy
            if(ny < 1) ny = ny + (1-(ny/ncubesy))*ncubesy
            if(nz > ncubesz) nz = nz - (nz/ncubesz)*ncubesz
            if(nz < 1) nz = nz + (1-(nz/ncubesz))*ncubesz

            !--- Reject if cubelet is not nitrogen-accessible ---
            if(lattice_space_n(nx, ny, nz) < 1) cycle

            !--- Overlap test using Verlet neighbor list ---
            deny = .false.
            do n=1, nneighbors(i)
                k = vlist(i, n)
                d1 = xp - coords(1, k)
                d2 = yp - coords(2, k)
                d3 = zp - coords(3, k)
                d1 = d1 - ell(1)*anint(d1/ell(1))
                d2 = d2 - ell(2)*anint(d2/ell(2))
                d3 = d3 - ell(3)*anint(d3/ell(3))
                rdist2 = d1*d1 + d2*d2 + d3*d3

                if(rdist2 < coeff_surface2 * asigma2_n(atype(k))) then
                    deny = .true.
                    exit
                end if
            end do

            if(deny) cycle
            ncount_arr(i) = ncount_arr(i) + 1
        end do  ! j = 1, nsample
    end do  ! i = 1, natoms
    !$acc end parallel loop

    !####################################################################
    ! Data transfer: copy results back
    !####################################################################
    !$acc exit data copyout(ncount_arr)

    !####################################################################
    ! CPU reduction: accumulate surface area
    !####################################################################
    stotal = 0.0d0
    do i=1, natoms
        if(ncount_arr(i) > 0) then
            sfrac = dble(ncount_arr(i)) / dble(nsample)
            sjreal = 4.0d0 * pi * coeff_surface2 * asigma2_n(atype(i)) * sfrac
            stotal = stotal + sjreal
        end if
    end do

    deallocate(ncount_arr)

    !--- Report results ---
    vol = fundcell_getvolume(fcell)
    stotalreduced = stotal / (vol) * 1.0d4

    write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
        ' surface area in A^2:                 ', stotal
    write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
        ' surface area per volume in m^2/cm^3: ', stotalreduced
    write(*,'(2a,f12.2)') " "//Trim(adjustl(property)), &
        ' surface area per mass in m^2/g:      ', &
        stotalreduced / (smass/(0.6022141d0*vol))
    write(*,*)
    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU surface area calculations complete                 !"
    write(*,*)

    write(100,*) property
    write(100,'(a,f12.2)') "S_AC_A^2 ", stotal
    write(100,'(a,f12.2)') "S_AC_m^2/cm^3 ", stotalreduced
    write(100,'(a,f12.2)') "S_AC_m^2/g ", &
        stotalreduced / (smass/(0.6022141d0*vol))

    call system_clock(t2)
    elapsed = dble(t2 - t1) / dble(t_rate)
    write(*,'(a,f8.2,a)') "  [TIMING] Surface area GPU took ", elapsed, " seconds"
    return
end subroutine surface_area_gpu


!--------------------------------------------------------------------------------------
! GPU-compatible random number generator
! Simple LCG (Linear Congruential Generator)
! Thread-safe: each thread has its own seed
! Returns uniform random in [0, 1)
!--------------------------------------------------------------------------------------
function gpu_rand(seed) result(r)
    implicit none
    !$acc routine vector
    integer, intent(inout) :: seed
    real*8  :: r
    integer :: new_seed

    ! LCG parameters (Numerical Recipes)
    ! x_{n+1} = (1664525 * x_n + 1013904223) mod 2^31
    new_seed = 1664525 * seed + 1013904223

    ! Keep in positive range
    if(new_seed < 0) new_seed = new_seed + 2147483647
    seed = mod(new_seed, 2147483647)
    if(seed < 0) seed = seed + 2147483647

    r = dble(seed) / 2147483647.0d0
    if(r < 0.0d0) r = 0.0d0
    if(r >= 1.0d0) r = 0.9999999999d0

    return
end function gpu_rand


!--------------------------------------------------------------------------------------
! GPU-accelerated pore size distribution
!
! The Monte Carlo search loop (the dominant cost) is parallelized on GPU.
! Each GPU gang handles one independent MC trial:
!   1. Pick a random accessible cubelet
    implicit none

    type(vectype) :: atvec1
    integer :: i, j, k, l, m, nx, ny, nz, nx1, ny1, nz1, icount
    integer :: bin, isite, ncycles, ivis, nc_local, jj, trial, idx
    real*8  :: sigma_ref, sigma2_ref, rdist2
    real*8  :: deldis1, deldis2, deldis
    real*8  :: x, y, z
    real*8  :: ell(3)
    integer, allocatable :: connolly_volume(:)
    integer :: is_total
    integer*8 :: t1, t2, t_rate, t_max
    real*8 :: elapsed

    ! GPU kernel temporaries
    real*8  :: rn, x1, y1, z1, x2, y2, z2, d1, d2, d3
    integer*8 :: seed, new_seed

    ! GPU arrays
    real*4, allocatable :: psd_gpu(:)
    integer :: ivis_gpu

    call system_clock(t1, t_rate, t_max)

    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU-accelerated pore size distribution                 !"
    write(*,*) "!-------------------------------------------------------!"
    write(*,*)

    if(.not. fcell%orthoflag) then
        write(*,*) "  Non-orthorhombic cell detected — using CPU version"
        call pore_distribution
        return
    end if

    ell = fcell%ell

    psd_cumul=0.0; psd=0.0
    icount = 0; ivis = 0
    ncycles = ncycles_psd
    ffv = 0.0; free_volume = 0.0

    allocate(connolly_volume(ncubesz*ncubesy*ncubesx))
    connolly_volume = 0
    volume = fundcell_getvolume(fcell)

    ! CPU: Fill PA arrays and sort
    if(property == "Total ") then
        is_total = 1
        do l=1, ncubesz; do k=1, ncubesy; do j=1, ncubesx
            if(lattice_space(j,k,l) < 1) cycle
            icount = icount + 1
            PA1(icount) = lattice_rdist2(j,k,l)
            PA2(icount) = j; PA3(icount) = k; PA4(icount) = l
        end do; end do; end do
        call sort(ng_cubes, PA1, PA2, PA3, PA4)
    else
        is_total = 0
        do l=1, ncubesz; do k=1, ncubesy; do j=1, ncubesx
            if(lattice_space_n(j,k,l) < 1) cycle
            icount = icount + 1
            PA1(icount) = lattice_rdist2(j,k,l)
            PA2(icount) = j; PA3(icount) = k; PA4(icount) = l
        end do; end do; end do
        call sort(nn_cubes, PA1, PA2, PA3, PA4)
    end if

    if(icount == 0) then
        write(*,*) "  No nitrogen accessible porosity "
        write(*,*); write(*,*) "!-------------------------------------------------------!"
        write(*,*) "! Pore size distribution calculations complete          !"
        write(*,*) "!-------------------------------------------------------!"; write(*,*)
        return
    end if

    if(property == "Total ") then
        nc_local = ng_cubes
    else
        nc_local = nn_cubes
    end if

    ! GPU working array
    allocate(psd_gpu(nbins+100))
    psd_gpu = 0.0
    ivis_gpu = 0

    ! GPU kernel: parallel MC trials
    !$acc enter data copyin(PA1, PA2, PA3, PA4, lattice_rdist2, g_cubes, &
    !$acc&   n_cubes, ell, cube_size, binsize, ncubesx, ncubesy, ncubesz, &
    !$acc&   ng_cubes, nn_cubes, nc_local, ncycles, nbins, is_total, ntot) &
    !$acc&   copyin(psd_gpu, ivis_gpu)

    !$acc parallel loop gang vector_length(32) &
    !$acc& private(rn, seed, new_seed, isite, idx, j, k, l, &
    !$acc&   nx1, ny1, nz1, x1, y1, z1, x2, y2, z2, d1, d2, d3, &
    !$acc&   rdist2, sigma2_ref, sigma_ref, bin, m, jj) &
    !$acc& firstprivate(ell, cube_size, binsize, ncubesx, ncubesy, &
    !$acc&   ncubesz, nc_local, ncycles, nbins, ng_cubes, nn_cubes, &
    !$acc&   is_total, ntot) &
    !$acc& present(PA1, PA2, PA3, PA4, lattice_rdist2, g_cubes, n_cubes, &
    !$acc&   psd_gpu, ivis_gpu)
    do trial=1, ncycles
        seed = 1_8 + trial * 694847539_8

        if(is_total == 1) then
            if(ng_cubes == 0) cycle
            new_seed = mod(1664525_8*seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            isite = int(rn * dble(ng_cubes)) + 1
            if(isite > ng_cubes) isite = ng_cubes
            idx = g_cubes(isite)
        else
            if(nn_cubes == 0) cycle
            new_seed = mod(1664525_8*seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            isite = int(rn * dble(nn_cubes)) + 1
            if(isite > nn_cubes) isite = nn_cubes
            idx = n_cubes(isite)
        end if

        ! Compute (j,k,l) from linear idx
        l = (idx - 1) / (ncubesx * ncubesy) + 1
        k = modulo((idx - 1) / ncubesx, ncubesy) + 1
        j = modulo(idx - 1, ncubesx) + 1

        x1 = dble(j-1)*cube_size + 0.5d0*cube_size
        y1 = dble(k-1)*cube_size + 0.5d0*cube_size
        z1 = dble(l-1)*cube_size + 0.5d0*cube_size

        ! Search PA from largest to smallest
        sigma2_ref = 0.0d0
        do jj = nc_local, 1, -1
            nx1 = PA2(jj); ny1 = PA3(jj); nz1 = PA4(jj)
            x2 = dble(nx1-1)*cube_size + 0.5d0*cube_size
            y2 = dble(ny1-1)*cube_size + 0.5d0*cube_size
            z2 = dble(nz1-1)*cube_size + 0.5d0*cube_size

            d1 = x1 - x2; d2 = y1 - y2; d3 = z1 - z2
            d1 = d1 - ell(1)*anint(d1/ell(1))
            d2 = d2 - ell(2)*anint(d2/ell(2))
            d3 = d3 - ell(3)*anint(d3/ell(3))
            rdist2 = d1*d1 + d2*d2 + d3*d3

            if(rdist2 <= lattice_rdist2(nx1, ny1, nz1)) then
                sigma2_ref = lattice_rdist2(nx1, ny1, nz1)
                exit
            end if
        end do

        if(sigma2_ref == 0.0d0) cycle

        sigma_ref = dsqrt(sigma2_ref)
        bin = int(2.0d0*sigma_ref/binsize) + 1
        if(bin > nbins) bin = nbins

        do m=1, bin
            !$acc atomic update
            psd_gpu(m) = psd_gpu(m) + 1.0
            !$acc end atomic
        end do

        !$acc atomic update
        ivis_gpu = ivis_gpu + 1
        !$acc end atomic
    end do
    !$acc end parallel loop

    ! Copy back
    !$acc exit data copyout(psd_gpu, ivis_gpu) &
    !$acc& delete(PA1, PA2, PA3, PA4, lattice_rdist2, g_cubes, n_cubes)

    do m=1, nbins
        psd_cumul(m) = psd_gpu(m)
    end do
    ivis = ivis_gpu
    deallocate(psd_gpu)

    ! ffv and free_volume
    ffv = dble(ivis) / dble(ncycles)
    if(property == "Total ") then
        ffv = ffv * dble(ng_cubes) / dble(ntot)
    else
        ffv = ffv * dble(nn_cubes) / dble(ntot)
    end if
    free_volume = ffv * volume

    ! CPU post-processing
    open(13, file=Trim(adjustl(property))//'_psd_cumulative.txt', status='unknown')
    open(14, file=Trim(adjustl(property))//'_psd.txt', status='unknown')
    write(13,*) '# Cumulative accessible volume distribution ...'
    write(13,*) '# '
    write(13,*) '# d(probe)                Volume Fraction'
    psd_cumul = psd_cumul / psd_cumul(1)
    do i=1, nbins
        write(13,*) binsize*real(i-1)-binsize/2.0, psd_cumul(i)
    end do
    psd(1)=0.0; psd(2)=0.0; psd(nbins)=0.0
    do i=2, nbins-1
        deldis1 = psd_cumul(i+1); deldis2 = psd_cumul(i-1)
        deldis = deldis1 - deldis2
        psd(i) = -1.0d0 * deldis / (binsize * 2.0d0)
    end do
    write(14,*) '# Derivative distribution function ...'
    do i=2, nbins-1
        write(14,*) binsize*real(i-1)-binsize/2.0, psd(i)
    end do
    close(13); close(14)

    ! Connolly volume output
    open(20, file='probe_occupiable_volume.xyz', status='unknown')
    write(20,*) ivis; write(20,*)
    do i=1, ivis
        isite = g_cubes(i)  ! simplified — uses trial index directly
        l = (isite - 1) / (ncubesx * ncubesy) + 1
        k = modulo((isite - 1) / ncubesx, ncubesy) + 1
        j = modulo(isite - 1, ncubesx) + 1
        x = dble(j-1)*cube_size + 0.5d0*cube_size
        y = dble(k-1)*cube_size + 0.5d0*cube_size
        z = dble(l-1)*cube_size + 0.5d0*cube_size
        x = x + fcell%mx; y = y + fcell%my; z = z + fcell%mz
        atvec1%comp(1) = x; atvec1%comp(2) = y; atvec1%comp(3) = z
        atvec1 = fundcell_unslant(fcell, atvec1)
        write(20,'(a,3f25.16)') "He ", atvec1%comp(1), atvec1%comp(2), atvec1%comp(3)
    end do
    close(20)

    call system_clock(t2)
    elapsed = dble(t2 - t1) / dble(t_rate)
    write(*,'(a,f8.2,a)') "  [TIMING] PSD GPU took ", elapsed, " seconds"
    write(*,*) Trim(adjustl(property)), " cumulative PSD and differential"
    write(*,*) "PSD have been stored in ..."
    write(*,*); write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! Pore size distribution calculations complete          !"
    write(*,*) "!-------------------------------------------------------!"; write(*,*)

    return
end subroutine pore_distribution_gpu

