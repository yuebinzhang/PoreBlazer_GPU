    use fundcell, only: fundcell_getvolume, fundcell_unslant
    use vector, only: vectype
    use defaults, only: rdbl
    implicit none

    type(vectype) :: atvec1
    integer :: i, j, k, l, m, nx, ny, nz, nx1, ny1, nz1, icount
    integer :: bin, isite, ncycles, ivis, nc_local, jj, trial, idx
    real*8  :: sigma_ref, sigma2_ref, rdist2
    real*8  :: deldis1, deldis2, deldis
    real*8  :: x, y, z
    real*8  :: ell(3)
    integer, allocatable :: connolly_volume(:)
    integer :: is_total
    integer*8 :: t1, t2, t_rate, t_max
    real*8 :: elapsed

    ! GPU kernel temporaries
    real*8  :: rn, x1, y1, z1, x2, y2, z2, d1, d2, d3
    integer*8 :: seed, new_seed

    ! GPU arrays
    real*4, allocatable :: psd_gpu(:)
    integer :: ivis_gpu

    call system_clock(t1, t_rate, t_max)

    write(*,*) "!-------------------------------------------------------!"
    write(*,*) "! GPU-accelerated pore size distribution                 !"
    write(*,*) "!-------------------------------------------------------!"
    write(*,*)

    if(.not. fcell%orthoflag) then
        write(*,*) "  Non-orthorhombic cell detected — using CPU version"
        call pore_distribution
        return
    end if

    ell = fcell%ell

    psd_cumul=0.0; psd=0.0
    icount = 0; ivis = 0
    ncycles = ncycles_psd
    ffv = 0.0; free_volume = 0.0

    allocate(connolly_volume(ncubesz*ncubesy*ncubesx))
    connolly_volume = 0
    volume = fundcell_getvolume(fcell)

    ! CPU: Fill PA arrays and sort
    if(property == "Total ") then
        is_total = 1
        do l=1, ncubesz; do k=1, ncubesy; do j=1, ncubesx
            if(lattice_space(j,k,l) < 1) cycle
            icount = icount + 1
            PA1(icount) = lattice_rdist2(j,k,l)
            PA2(icount) = j; PA3(icount) = k; PA4(icount) = l
        end do; end do; end do
        call sort(ng_cubes, PA1, PA2, PA3, PA4)
    else
        is_total = 0
        do l=1, ncubesz; do k=1, ncubesy; do j=1, ncubesx
            if(lattice_space_n(j,k,l) < 1) cycle
            icount = icount + 1
            PA1(icount) = lattice_rdist2(j,k,l)
            PA2(icount) = j; PA3(icount) = k; PA4(icount) = l
        end do; end do; end do
        call sort(nn_cubes, PA1, PA2, PA3, PA4)
    end if

    if(icount == 0) then
        write(*,*) "  No nitrogen accessible porosity "
        write(*,*); write(*,*) "!-------------------------------------------------------!"
        write(*,*) "! Pore size distribution calculations complete          !"
        write(*,*) "!-------------------------------------------------------!"; write(*,*)
        return
    end if

    if(property == "Total ") then
        nc_local = ng_cubes
    else
        nc_local = nn_cubes
    end if

