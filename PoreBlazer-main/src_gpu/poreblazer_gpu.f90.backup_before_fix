        k = modulo((idx - 1) / ncubesx, ncubesy) + 1
        j = modulo(idx - 1, ncubesx) + 1

        x1 = dble(j-1)*cube_size + 0.5d0*cube_size
        y1 = dble(k-1)*cube_size + 0.5d0*cube_size
        z1 = dble(l-1)*cube_size + 0.5d0*cube_size

