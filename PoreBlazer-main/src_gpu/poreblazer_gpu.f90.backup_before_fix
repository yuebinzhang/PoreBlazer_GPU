        do m=1, bin
            !$acc atomic update
            psd_gpu(m) = psd_gpu(m) + 1.0
            !$acc end atomic
        end do

        !$acc atomic update
        ivis_gpu = ivis_gpu + 1
        !$acc end atomic
    end do
