    !$acc&   n_cubes, ell, cube_size, binsize, ncubesx, ncubesy, ncubesz, &
    !$acc&   ng_cubes, nn_cubes, nc_local, ncycles, nbins, is_total, ntot) &
    !$acc&   copyin(psd_gpu, ivis_gpu)

    !$acc parallel loop gang vector_length(32) &
    !$acc& private(rn, seed, new_seed, isite, idx, j, k, l, &
    !$acc&   nx1, ny1, nz1, x1, y1, z1, x2, y2, z2, d1, d2, d3, &
    !$acc&   rdist2, sigma2_ref, sigma_ref, bin, m, jj) &
    !$acc& firstprivate(ell, cube_size, binsize, ncubesx, ncubesy, &
    !$acc&   ncubesz, nc_local, ncycles, nbins, ng_cubes, nn_cubes, &
    !$acc&   is_total, ntot) &
    !$acc& present(PA1, PA2, PA3, PA4, lattice_rdist2, g_cubes, n_cubes, &
    !$acc&   psd_gpu, ivis_gpu)
    do trial=1, ncycles
        seed = 1_8 + trial * 694847539_8

        if(is_total == 1) then
            if(ng_cubes == 0) cycle
            new_seed = mod(1664525_8*seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            isite = int(rn * dble(ng_cubes)) + 1
            if(isite > ng_cubes) isite = ng_cubes
            idx = g_cubes(isite)
        else
            if(nn_cubes == 0) cycle
            new_seed = mod(1664525_8*seed + 1013904223_8, 2147483647_8)
            seed = new_seed
            rn = dble(seed) / 2147483647.0d0
            isite = int(rn * dble(nn_cubes)) + 1
            if(isite > nn_cubes) isite = nn_cubes
            idx = n_cubes(isite)
        end if

        ! Compute (j,k,l) from linear idx
        l = (idx - 1) / (ncubesx * ncubesy) + 1
        k = modulo((idx - 1) / ncubesx, ncubesy) + 1
        j = modulo(idx - 1, ncubesx) + 1

        x1 = dble(j-1)*cube_size + 0.5d0*cube_size
        y1 = dble(k-1)*cube_size + 0.5d0*cube_size
        z1 = dble(l-1)*cube_size + 0.5d0*cube_size

        ! Search PA from largest to smallest
        sigma2_ref = 0.0d0
        do jj = nc_local, 1, -1
            nx1 = PA2(jj); ny1 = PA3(jj); nz1 = PA4(jj)
            x2 = dble(nx1-1)*cube_size + 0.5d0*cube_size
            y2 = dble(ny1-1)*cube_size + 0.5d0*cube_size
            z2 = dble(nz1-1)*cube_size + 0.5d0*cube_size

            d1 = x1 - x2; d2 = y1 - y2; d3 = z1 - z2
            d1 = d1 - ell(1)*anint(d1/ell(1))
            d2 = d2 - ell(2)*anint(d2/ell(2))
            d3 = d3 - ell(3)*anint(d3/ell(3))
            rdist2 = d1*d1 + d2*d2 + d3*d3

            if(rdist2 <= lattice_rdist2(nx1, ny1, nz1)) then
                sigma2_ref = lattice_rdist2(nx1, ny1, nz1)
                exit
            end if
        end do

        if(sigma2_ref == 0.0d0) cycle

        sigma_ref = dsqrt(sigma2_ref)
        bin = int(2.0d0*sigma_ref/binsize) + 1
        if(bin > nbins) bin = nbins

        do m=1, bin
            !$acc atomic update
            psd_gpu(m) = psd_gpu(m) + 1.0
            !$acc end atomic
        end do

        !$acc atomic update
        ivis_gpu = ivis_gpu + 1
        !$acc end atomic
    end do
    !$acc end parallel loop

    ! Copy back
    !$acc exit data copyout(psd_gpu, ivis_gpu) &
    !$acc& delete(PA1, PA2, PA3, PA4, lattice_rdist2, g_cubes, n_cubes)

    do m=1, nbins
        psd_cumul(m) = psd_gpu(m)
    end do
    ivis = ivis_gpu
    deallocate(psd_gpu)

    ! ffv and free_volume
    ffv = dble(ivis) / dble(ncycles)
    if(property == "Total ") then
        ffv = ffv * dble(ng_cubes) / dble(ntot)
    else
        ffv = ffv * dble(nn_cubes) / dble(ntot)
    end if
    free_volume = ffv * volume

    ! CPU post-processing
    open(13, file=Trim(adjustl(property))//'_psd_cumulative.txt', status='unknown')
    open(14, file=Trim(adjustl(property))//'_psd.txt', status='unknown')
    write(13,*) '# Cumulative accessible volume distribution ...'
    write(13,*) '# '
    write(13,*) '# d(probe)                Volume Fraction'
    psd_cumul = psd_cumul / psd_cumul(1)
    do i=1, nbins
        write(13,*) binsize*real(i-1)-binsize/2.0, psd_cumul(i)
    end do
    psd(1)=0.0; psd(2)=0.0; psd(nbins)=0.0
    do i=2, nbins-1
        deldis1 = psd_cumul(i+1); deldis2 = psd_cumul(i-1)
        deldis = deldis1 - deldis2
        psd(i) = -1.0d0 * deldis / (binsize * 2.0d0)
    end do
    write(14,*) '# Derivative distribution function ...'
    do i=2, nbins-1
        write(14,*) binsize*real(i-1)-binsize/2.0, psd(i)
    end do
    close(13); close(14)

    ! Connolly volume output
